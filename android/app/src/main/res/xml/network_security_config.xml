<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Reject all cleartext (plain HTTP) traffic app-wide. All API calls and
         image loads must use TLS. -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
